{$API_DOMAIN} {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    -Server
  }

  # CI/run-plane callers reach the otherwise loopback-only admin API through
  # narrow bearer-token-gated routes only - not the full /internal/admin
  # surface. See D-046 in docs/DECISIONS.md and docs/BOT_ARENA_PLAN.md's
  # "Resolved Slice: Bot Submission Workflow And OpenBao Provisioning".
  @ci_admin {
    path /internal/admin/arena/bots
    path /internal/admin/arena/bots/openbao-provision
  }

  @analytics_export {
    method POST
    path /internal/admin/analytics/run-exports
  }

  handle @ci_admin {
    @unauthorized not header Authorization "Bearer {$ARENA_ADMIN_API_TOKEN}"
    respond @unauthorized 401

    reverse_proxy platform-runtime:8080
  }

  handle @analytics_export {
    @unauthorized not header Authorization "Bearer {$ANALYTICS_EXPORT_API_TOKEN}"
    respond @unauthorized 401

    reverse_proxy platform-runtime:8080
  }

  handle {
    respond 404
  }
}
