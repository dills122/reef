{$API_DOMAIN} {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    -Server
  }

  # CI/run-plane callers use versioned admin gateway paths. Raw /internal/*
  # HTTP routes remain private to the runtime container.
  @ci_admin {
    path /admin/v1/arena/bots
    path /admin/v1/arena/bots/openbao-provision
  }

  @analytics_export {
    method POST
    path /admin/v1/analytics/run-exports
  }

  handle @ci_admin {
    @unauthorized not header Authorization "Bearer {$ARENA_ADMIN_API_TOKEN}"
    respond @unauthorized 401

    reverse_proxy platform-runtime:8080
  }

  handle @analytics_export {
    @unauthorized not header Authorization "Bearer {$ANALYTICS_EXPORT_API_TOKEN}"
    respond @unauthorized 401

    reverse_proxy platform-runtime:8080
  }

  handle {
    respond 404
  }
}
