# Optional. Only needed when running the public Caddy profile.
# API_DOMAIN=api.example.com

REEF_PLATFORM_RUNTIME_IMAGE=ghcr.io/dills122/reef-platform-runtime:latest
REEF_MATCHING_ENGINE_IMAGE=ghcr.io/dills122/reef-matching-engine:latest
REEF_SIMULATOR_IMAGE=ghcr.io/dills122/reef-simulator:latest

# Registry/namespace prefix used by the restricted application auto-deployer.
# Production currently uses Docker Hub; use ghcr.io/dills122 to select GHCR.
REEF_AUTO_DEPLOY_IMAGE_NAMESPACE=dills122
