{
	"name": "arena-admin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun ../../scripts/dev/arena-admin-tool.mjs dev",
		"build": "bun ../../scripts/dev/arena-admin-tool.mjs build",
		"build:guarded": "bun ../../scripts/dev/arena-admin-tool.mjs build && node scripts/assert-production-build-no-local-fixtures.mjs",
		"preview": "bun ../../scripts/dev/arena-admin-tool.mjs preview",
		"prepare": "bun ../../scripts/dev/arena-admin-tool.mjs sync-optional",
		"check": "bun ../../scripts/dev/arena-admin-tool.mjs check",
		"check:watch": "bun ../../scripts/dev/arena-admin-tool.mjs check --watch"
	},
	"devDependencies": {
		"@fontsource/courier-prime": "^5.3.0",
		"@sveltejs/adapter-static": "^3.0.10",
