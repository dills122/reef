		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"clsx": "^2.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.7.3",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
