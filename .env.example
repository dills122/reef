# Copy to ".env" and adjust for your machine.

## Common local stack overrides

# Optional compose profiles: redis, observability, or redis,observability
DEV_COMPOSE_PROFILES=
# Optional ordered compose file list.
# Leave blank for the default layered local stack: compose.base.yml,compose.local.yml.
# Compatibility monolith: REEF_COMPOSE_FILES=docker-compose.yml
REEF_COMPOSE_FILES=

# Host port overrides (useful when defaults conflict)
REEF_PLATFORM_RUNTIME_HOST_PORT=8080
REEF_MATCHING_ENGINE_HOST_PORT=8081
REEF_MATCHING_ENGINE_GRPC_HOST_PORT=9081
REEF_POSTGRES_HOST_PORT=5432
REEF_PROJECTION_POSTGRES_HOST_PORT=5433
REEF_BOUNDARY_POSTGRES_HOST_PORT=5434
REEF_ARENA_POSTGRES_HOST_PORT=5435
REEF_REDIS_HOST_PORT=6379
REEF_JAEGER_UI_HOST_PORT=16686
REEF_OTEL_GRPC_HOST_PORT=4317
REEF_OTEL_HTTP_HOST_PORT=4318

## Local datastore defaults

# Postgres write-path tuning (dev soak defaults)
REEF_PG_MAX_WAL_SIZE=16GB
REEF_PG_MIN_WAL_SIZE=4GB
REEF_PG_CHECKPOINT_TIMEOUT=15min
REEF_PG_CHECKPOINT_COMPLETION_TARGET=0.9
REEF_PG_WAL_COMPRESSION=on
REEF_PG_LOG_CHECKPOINTS=on

# Optional direct endpoint overrides (normally derived from host ports)
RUNTIME_BASE_URL=
ENGINE_BASE_URL=

## Runtime mode and transport selection

# Runtime -> matching-engine transport.
# gRPC is the dev default because high-load local tests showed materially higher throughput.
# Set ENGINE_TRANSPORT=http and MATCHING_ENGINE_ENABLE_GRPC=0 to compare the legacy HTTP path.
ENGINE_TRANSPORT=grpc
MATCHING_ENGINE_ENABLE_GRPC=1
MATCHING_ENGINE_GRPC_TARGET=matching-engine:9081
ENGINE_GRPC_DEADLINE_MS=2000

## Advanced throughput tuning

# Hot-path tuning knobs for local throughput sweeps.
PLATFORM_HTTP_THREADS=64
RUNTIME_DB_POOL_MAX=48
RUNTIME_DB_POOL_MIN_IDLE=16
RUNTIME_DB_POOL_CONN_TIMEOUT_MS=2000
# Optional per-pool overrides. Pool names are exposed by /internal/perf/db-pools.
# Named pools use conservative role defaults unless overridden, so the global pool
# settings do not multiply directly across every runtime-managed pool.
# RUNTIME_DB_POOL_COMMAND_LOG_MAX=48
# RUNTIME_DB_POOL_ASYNC_RUNTIME_MAX=16
# RUNTIME_DB_POOL_IDEMPOTENCY_MAX=8

# Local/internal mutation routes for dev seeding/admin only.
# Code default is false; local compose opts in explicitly.
PLATFORM_INTERNAL_HTTP_MODE=local
PLATFORM_LEGACY_MUTATION_ROUTES_ENABLED=true

## Optional product/control-plane features

# P2 settlement fact API. Defaults to runtime Postgres when RUNTIME_POSTGRES_JDBC_URL is set.
PLATFORM_SETTLEMENT_FACTS_ENABLED=true
SETTLEMENT_POSTGRES_JDBC_URL=
SETTLEMENT_POSTGRES_SCHEMA=settlement

# Arena control-plane DB is intentionally separate from runtime/boundary/projection DBs.
ARENA_POSTGRES_JDBC_URL=jdbc:postgresql://arena-postgres:5432/reef?currentSchema=arena
ARENA_POSTGRES_USER=reef
ARENA_POSTGRES_PASSWORD=reef
PLATFORM_ARENA_ADMIN_ENABLED=false
EXTERNAL_API_ARENA_BOT_VERSION_RISK_ENABLED=false

# Admin HTTP auth is opt-in. For local browser testing over plain HTTP, keep
# ADMIN_SESSION_COOKIE_SECURE=false. Hosted environments should use true.
PLATFORM_ADMIN_AUTH_ENABLED=false
# Static bearer fallback tokens for admin gateway scripts and hosted edge
# compatibility. Prefer scoped service tokens for long-lived automation.
ADMIN_API_TOKEN=
ARENA_ADMIN_API_TOKEN=
ANALYTICS_EXPORT_API_TOKEN=
# Optional server-side actor bindings for static fallback tokens. Defaults to
# ADMIN_ACTOR_ID when omitted; never supplied by request headers.
ADMIN_API_ACTOR_ID=
ARENA_ADMIN_API_ACTOR_ID=
ANALYTICS_EXPORT_API_ACTOR_ID=
# Opt-in local-only fake admin session for browser development when OAuth is not
# reachable. The runtime accepts it only for loopback requests and local profiles.
LOCAL_DEV_ADMIN_AUTH_BYPASS=false
ADMIN_POSTGRES_JDBC_URL=
ADMIN_POSTGRES_USER=
ADMIN_POSTGRES_PASSWORD=
ADMIN_SESSION_COOKIE_NAME=reef_admin_session
ADMIN_SESSION_COOKIE_SECURE=false
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/admin/auth/github/callback

# Stock-data seed service. Seed-time-only external reference fetch for new
# game/simulation state - see docs/STOCK_DATA_SEEDING_PLAN.md and
# services/stock-data/README.md. Not wired into compose yet.
STOCK_DATA_PROVIDER=tiingo
STOCK_DATA_API_TOKEN=
STOCK_DATA_HTTP_MAX_REQUEST_BYTES=65536
STOCK_DATA_MAX_SEED_SYMBOLS=100
TIINGO_API_TOKEN=
STOCK_DATA_CURRENT_MAX_AGE_SECONDS=900
STOCK_DATA_PROVIDER_TIMEOUT_MS=2500
STOCK_DATA_PROVIDER_MAX_RETRIES=2
STOCK_DATA_ALLOW_STALE_CACHE=false
STOCK_DATA_PERSISTENCE=inmemory
STOCK_DATA_POSTGRES_JDBC_URL=jdbc:postgresql://localhost:5432/reef?currentSchema=stock_data
STOCK_DATA_POSTGRES_USER=reef
STOCK_DATA_POSTGRES_PASSWORD=reef

## Command intake and durability modes

# Boundary durability (persist captured inbound /api/v1 commands)
# Options: postgres | inmemory | disabled
EXTERNAL_API_COMMAND_CAPTURE_MODE=postgres
# Optional append-only command-log intake slice.
# Options: disabled | postgres | inmemory
EXTERNAL_API_COMMAND_LOG_MODE=disabled
# Command-log append implementation.
# Options: inline | function
EXTERNAL_API_COMMAND_LOG_APPEND_MODE=inline
# Command-log request payload storage.
# Options: side-table | inline
EXTERNAL_API_COMMAND_LOG_PAYLOAD_MODE=side-table
# Command processing mode.
# Options: sync-result | captured-sync-engine | captured-ack
EXTERNAL_API_COMMAND_PROCESSING_MODE=sync-result
# Captured-ack async worker tuning used by make dev-up-captured-ack.
EXTERNAL_API_COMMAND_ASYNC_WORKER_ENABLED=false
EXTERNAL_API_COMMAND_ASYNC_WORKER_THREADS=4
EXTERNAL_API_COMMAND_ASYNC_WORKER_BATCH_SIZE=250
EXTERNAL_API_COMMAND_ASYNC_WORKER_POLL_MS=5
EXTERNAL_API_COMMAND_ASYNC_WORKER_LEASE_MS=60000
EXTERNAL_API_COMMAND_ASYNC_WORKER_DEDICATED_RUNTIME_POOL_ENABLED=false

## Optional boundary guardrails

# Optional abuse-breaker guardrail for /api/v1 writes
# Mode: off | reject-rate
EXTERNAL_API_ABUSE_BREAKER_MODE=off
EXTERNAL_API_ABUSE_BREAKER_MAX_REJECTS=50
EXTERNAL_API_ABUSE_BREAKER_WINDOW_SECONDS=30
EXTERNAL_API_ABUSE_BREAKER_BLOCK_SECONDS=60
EXTERNAL_API_ABUSE_BREAKER_REJECT_CODES=INVALID_STATE,NOT_FOUND,REFERENCE_DATA_ERROR,VALIDATION_ERROR
EXTERNAL_API_ABUSE_BREAKER_ROUTES=/api/v1/orders/submit,/api/v1/orders/modify,/api/v1/orders/cancel
# Optional per-route overrides (route:maxRejects/windowSeconds/blockSeconds, comma-delimited)
EXTERNAL_API_ABUSE_BREAKER_ROUTE_POLICIES=
EXTERNAL_API_ABUSE_BREAKER_WARN_ONLY=false

## Benchmark and diagnostic defaults

# Stress defaults
DEV_STRESS_DURATION=30s
DEV_STRESS_WORKERS=12
DEV_STRESS_TRACE_CHECK_LIMIT=100
DEV_STRESS_REPORT_OUT=/tmp/reef-load-report-dev-stress.json
DEV_STRESS_DB_SCHEMAS=runtime,boundary,command_log

# Intake benchmark diagnostics
DEV_INTAKE_CAPTURE_DB_DIAGNOSTICS=1
DEV_INTAKE_DB_SCHEMAS=runtime,boundary,command_log

# Command-log terminal history pruning.
# Dry-run by default; set DEV_COMMAND_LOG_PRUNE_APPLY=1 to delete eligible terminal rows.
DEV_COMMAND_LOG_PRUNE_OLDER_THAN=24h
DEV_COMMAND_LOG_PRUNE_BATCH_SIZE=50000
DEV_COMMAND_LOG_PRUNE_MAX_BATCHES=100
DEV_COMMAND_LOG_PRUNE_VACUUM=1
DEV_COMMAND_LOG_PRUNE_CAPTURE_DB_DIAGNOSTICS=1

# Command-log retention pins protect named sessions/runs from prune.
DEV_COMMAND_LOG_PIN_ACTION=list
DEV_COMMAND_LOG_PIN_SELECTOR_TYPE=idempotency_prefix
DEV_COMMAND_LOG_PIN_SELECTOR_VALUE=
DEV_COMMAND_LOG_PIN_REASON=local retention pin

# Simulator command-path defaults
REEF_USE_API_V1=true
REEF_CLIENT_ID_PREFIX=sim-client
